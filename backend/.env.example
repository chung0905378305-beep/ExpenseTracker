# SQLite 本地数据库文件（零依赖，无需 Docker）
DATABASE_URL="file:./dev.db"

# JWT 密钥（生产务必替换为随机 64 位 hex：node -e "require('crypto').randomBytes(32).toString('hex')"）
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="1h"

# 后端端口
PORT=4000

# 允许的前端来源（CORS，逗号分隔多个）
WEB_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"

# App 端调用会员校验接口用的密钥（iOS App 内置，生产务必替换为 ak- 前缀随机串）
APP_API_KEY="ak-change-me-in-production"
